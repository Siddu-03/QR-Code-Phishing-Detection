# --- QR Shield Backend Environment Config ---

# App
APP_NAME=QR Shield API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security
API_KEY=change-me-in-production
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/jpg,image/webp

# QR Shield Core (existing CV modules from Weeks 1-4)
# Path to the directory containing image_loader, tamper_analysis, dataset_management
QR_SHIELD_CORE_PATH=../qr_shield_core

# Storage
UPLOAD_DIR=./storage/uploads
REPORT_DIR=./storage/reports
HISTORY_FILE=./storage/history.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=./storage/logs/backend.log
